# ─── Copie este arquivo para .env e preencha os valores ───────────────────────
# cp .env.example .env

# Chave secreta da aplicação
# Gere com: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-secreta-forte

# Banco de dados
# Desenvolvimento (padrão — sem configuração necessária):
#DATABASE_URL=sqlite:///taskmanager.db

# Produção — defina com PostgreSQL:
DATABASE_URL=postgresql://postgres:efq170880@localhost:5432/taskmanager

# ── E-mail (Flask-Mail) ─────────────────────────────────
# Exemplo com Gmail (use uma App Password, não sua senha real)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=edimilsonqueiroz681@gmail.com
MAIL_PASSWORD=efq170880
MAIL_DEFAULT_SENDER=TaskFlow <edimilsonqueiroz681@gmail.com>

# Ambiente
FLASK_ENV=production
FLASK_DEBUG=0